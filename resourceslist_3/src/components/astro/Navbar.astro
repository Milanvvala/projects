---
import { Image } from "astro:assets";
import { nav } from "@/lib/nav";
import { Button } from "@/components/ui/button";
import MobileMenu from "@/components/react/Menu";
---
<section class="py-4 border-b">
    <div class="container mx-auto px-4">
        <nav class="hidden items-center justify-between lg:flex">
            <div class="flex items-center gap-4">
                <!-- Logo -->
                <a href={nav.logo.url} class="flex items-center gap-2">
                    <Image
                        src={nav.logo.src}
                        height={32}
                        width={160}
                        class="object-contain"
                        alt={nav.logo.alt}
                    />
                    <!-- <span class="text-lg font-semibold">{nav.logo.title}</span> -->
                </a>
            </div>

            <div class="flex items-center gap-3">
                <!-- Navigation -->
                <div class="flex items-center">
                    <ul class="flex items-center gap-1">
                        {
                            nav.menu.map((item) => (
                                <li id={item.title}>
                                    <a
                                        class="group inline-flex h-10 w-max items-center justify-center rounded-md px-3 py-2 text-sm font-medium text-muted-foreground transition-colors hover:text-primary"
                                        href={item.url}
                                    >
                                        {item.title}
                                    </a>
                                </li>
                            ))
                        }
                    </ul>
                </div>

                <!-- Buttons -->
                <Button variant="outline" size="sm">
                    <a href={nav.auth.login.url}>{nav.auth.login.text}</a>
                </Button>
                <Button size="sm">
                    <a href={nav.auth.signup.url}>{nav.auth.signup.text}</a>
                </Button>
            </div>
        </nav>

        <!-- Mobile Menu-->
        <div class="block lg:hidden">
            <div class="flex items-center justify-between">
                <!-- Logo -->
                <a href={nav.logo.url} class="flex items-center gap-2">
                    <Image
                        src={nav.logo.src}
                        width={120}
                        height={24}
                        class="object-contain"
                        alt={nav.logo.alt}
                    />
                    <!-- <span class="text-lg font-semibold">{nav.logo.title}</span> -->
                </a>

                <!-- Menu -->
                <MobileMenu client:load />
            </div>
        </div>
    </div>
</section>
