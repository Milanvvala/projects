---
import Hero from "@/components/astro/Hero.astro";
import Layout from "../layouts/Layout.astro";
import Featured from "@/components/astro/Featured.astro";
import ResourcesGrid from "@/components/astro/ResourcesGrid.astro";
---

<Layout>
	<div id="container">
		<Hero />
		<div class="container mx-auto px-4">
			<h2 class="text-3xl font-bold">Featured</h2>
		</div>
		<Featured />
		<div class="container mx-auto px-4">
			<h2 class="text-3xl font-bold">All Resources</h2>
		</div>
		<div class="container mx-auto px-4">
			<ResourcesGrid />
		</div>
	</div>
</Layout>
